generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AssetType {
  DOMAIN
  IP
}

enum AssetStatus {
  PENDING
  VERIFIED
}

enum FindingSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  assets    Asset[]
}

model Asset {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id])

  type      AssetType
  value     String
  status    AssetStatus @default(PENDING)
  critical  Boolean     @default(false)
  createdAt DateTime    @default(now())

  verifications AssetVerification[]
  scanRuns       ScanRun[]
  findings       Finding[]

  @@index([userId])
  @@unique([type, value, userId])
}

model AssetVerification {
  id         String   @id @default(cuid())
  assetId    String
  asset      Asset    @relation(fields: [assetId], references: [id])

  method     String   // DNS_TXT | HTTP_FILE (MVP)
  token      String
  createdAt  DateTime @default(now())
  verifiedAt DateTime?

  @@index([assetId])
}

model ScanRun {
  id         String   @id @default(cuid())
  assetId    String
  asset      Asset    @relation(fields: [assetId], references: [id])

  startedAt  DateTime @default(now())
  finishedAt DateTime?
  status     String   @default("RUNNING") // RUNNING|DONE|FAILED

  findings   Finding[]

  @@index([assetId])
}

model Finding {
  id        String   @id @default(cuid())
  assetId   String
  asset     Asset    @relation(fields: [assetId], references: [id])

  scanRunId String
  scanRun   ScanRun  @relation(fields: [scanRunId], references: [id])

  type       String          // HTTP_HEALTH / TLS_EXPIRY / PORT_EXPOSED / DNS_CHANGE ...
  key        String          // STABLE KEY (örn: HTTP_HEALTH:example.com)
  severity   FindingSeverity @default(LOW)

  dataJson   Json
  aiScore    Int
  aiWhyJson  Json

  isNew      Boolean  @default(true)

  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())

  @@index([assetId])
  @@index([scanRunId])
  @@index([aiScore])
  @@unique([assetId, key])
}